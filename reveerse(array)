#include <stdio.h>

// Function to reverse the array using two pointers
void reverseArray(int arr[], int n) {
    int start = 0;         // Pointer to the first element
    int end = n - 1;       // Pointer to the last element
    int temp;

    // Loop until the pointers meet in the middle
    while (start < end) {
        // Swap elements at the start and end positions
        temp = arr[start];
        arr[start] = arr[end];
        arr[end] = temp;

        // Move pointers towards the center
        start++;
        end--;
    }
}

// Function to print the array (for demonstration)
void printArray(int arr[], int n) {
    for (int i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }
    printf("\n");
}

int main() {
    // Example array
    int arr[] = {1, 2, 3, 4, 5};
    // Calculate the size of the array
    int n = sizeof(arr) / sizeof(arr[0]);

    printf("Original array: ");
    printArray(arr, n);

    // Call the function to reverse the array
    reverseArray(arr, n);

    printf("Reversed array: ");
    printArray(arr, n);

    return 0;
}
