#include <stdio.h>

int main() {
    int size, i, largest;
    
    // Prompt the user to enter the size of the array
    printf("Enter the number of elements (1 to 100): ");
    scanf("%d", &size);

    // Declare an array of the specified size
    int array[size];

    // Input array elements from the user
    printf("Enter %d elements of the array:\n", size);
    for (i = 0; i < size; i++) {
        printf("Element %d: ", i + 1);
        scanf("%d", &array[i]);
    }

    // Initialize the 'largest' variable with the first element
    largest = array[0];

    // Iterate through the rest of the array to find the largest element
    for (i = 1; i < size; i++) {
        if (array[i] > largest) {
            largest = array[i]; // Update 'largest' if a bigger element is found
        }
    }

    // Print the largest element found
    printf("The largest element in the array is: %d\n", largest);

    return 0;
}
